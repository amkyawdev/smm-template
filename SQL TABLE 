-- Create tables for the SMM Service Website

-- Site Settings Table
CREATE TABLE site_settings (
    id SERIAL PRIMARY KEY,
    site_title VARCHAR(255) DEFAULT 'SMM Service',
    subtitle_text VARCHAR(500) DEFAULT 'Premium Social Media Marketing',
    telegram_link VARCHAR(500) DEFAULT 'https://t.me/yourchannel',
    floating_icon_enabled BOOLEAN DEFAULT TRUE,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Admin Users Table
CREATE TABLE admin_users (
    id SERIAL PRIMARY KEY,
    username VARCHAR(100) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Pricing Table
CREATE TABLE pricing (
    id SERIAL PRIMARY KEY,
    service_type VARCHAR(50) NOT NULL, -- 'followers', 'views', 'likes', 'comments'
    package_name VARCHAR(100) NOT NULL,
    quantity INTEGER NOT NULL,
    price_kyat DECIMAL(10,2) NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

