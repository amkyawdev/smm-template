{
  "version": 2,
  "builds": [
    {
      "src": "server/neondb.py",
      "use": "@vercel/python"
    },
    {
      "src": "**/*",
      "use": "static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/neondb.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.9"
  }
}
